# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=web_crawler

# ElasticSearch
ES_URI=http://localhost:9200
ES_INDEX=crawled_pages

# RabbitMQ
RABBITMQ_URI=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=url_queue

# Crawler
MAX_WORKERS=5
MAX_DEPTH=3
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=1.0
RESPECT_ROBOTS_TXT=true
USER_AGENT=WebCrawler/1.0 (+https://github.com/seu-usuario/web-crawler)
